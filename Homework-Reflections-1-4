### num_bins = 10
df["W_bin"] = pd.cut(df["W"], bins=num_bins)
bin_effects = []
for w_bin, group in df.groupby("W_bin"):

    if group["Z"].nunique() < 2:
        continue
    
    y_z1 = group.loc[group["Z"] == 1, "Y"].mean()
    y_z0 = group.loc[group["Z"] == 0, "Y"].mean()
    
    x_z1 = group.loc[group["Z"] == 1, "X"].mean()
    x_z0 = group.loc[group["Z"] == 0, "X"].mean()
    
    y_diff = y_z1 - y_z0
    x_diff = x_z1 - x_z0
    if abs(x_diff) > 1e-8:
        effect = y_diff / x_diff
        bin_effects.append(effect)
average_effect = np.mean(bin_effects)
### Most of the bin-level instrumental variable estimates were positive and fell between approximately 1.1 and 1.8. However, one bin produced a large negative estimate (-3.69), which reduced the overall average effect to 0.91. This shows that the binning approach can be sensitive to outliers and bins where the difference in X between Z=1 and Z=0 is very small. While dividing W into ranges helps control for variation in W, the resulting estimates may become unstable when certain bins contain limited information or weak instrument effects


